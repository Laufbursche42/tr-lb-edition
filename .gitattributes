# Keep text files as LF in the repository so the shell scripts and CI
# (build-release-notes.sh, the git hooks, gradlew) run correctly on the
# Linux GitHub Actions runners regardless of the contributor's OS.
* text=auto eol=lf

# The Windows batch launcher must keep CRLF.
*.bat text eol=crlf

# Binary assets - never apply end-of-line conversion to these.
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.ico  binary
*.jar  binary
*.apk  binary
*.keystore binary
*.jks  binary
*.map  binary
*.rd5  binary
*.dat  binary
