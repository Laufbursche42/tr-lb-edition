<?xml version="1.0" encoding="utf-8"?>
<!--
  TR-LB Edition launcher background - subtle dark radial gradient (#101418
  family) giving a soft center glow / vignette so the lime scooter mark reads
  cleanly under any launcher mask. Original artwork.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54" android:centerY="49"
                android:gradientRadius="80">
                <item android:offset="0" android:color="#FF1A222C" />
                <item android:offset="0.6" android:color="#FF101418" />
                <item android:offset="1" android:color="#FF0A0D11" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
