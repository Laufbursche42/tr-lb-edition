<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Bluetooth (classic + BLE, API 31+ split permissions) -->
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30"/>
    <!-- usesPermissionFlags is honoured on API 31+ and harmlessly ignored below (min is 26);
         it is intentionally declared so the scan never implies location on modern devices. -->
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:ignore="UnusedAttribute"/>
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>

    <!-- Location (needed for BLE scan on older APIs and for GPS route recording) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!-- Streaming / networking / foreground service -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_CONNECTED_DEVICE"/>
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE"/>

    <uses-feature android:name="android.hardware.bluetooth_le" android:required="false"/>

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:theme="@style/Theme.LBEdition"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:allowBackup="false">

        <!-- The dashboard is a purpose-built portrait riding gauge (mounted on handlebars); it is
             intentionally locked to portrait. LockedOrientationActivity / DiscouragedApi are
             suppressed here rather than unlocking rotation, which the fixed layout does not support. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:configChanges="orientation|screenSize|keyboardHidden"
            tools:ignore="LockedOrientationActivity,DiscouragedApi">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Offline navigation (Mapsforge map + BRouter bike routing + POI overlays) -->
        <activity
            android:name=".NavActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>

        <!-- In-app offline map download manager (EU country Mapsforge .map files over HTTPS) -->
        <activity
            android:name=".MapDownloadActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"/>

        <!-- Foreground service that downloads offline maps so the transfer survives screen-off -->
        <service
            android:name=".MapDownloadService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Foreground service kept alive only during an active ride so the ride log keeps
             sampling (and BLE stays connected) with the screen off. -->
        <service
            android:name="com.lb.edition.RideLoggerService"
            android:exported="false"
            android:foregroundServiceType="connectedDevice"/>

        <!-- Foreground service that owns an active turn-by-turn navigation session (GPS + voice
             guidance) so navigation survives leaving the map screen and keeps announcing on the
             dashboard. Started only internally by NavActivity; stopped by the user (End). -->
        <service
            android:name=".NavigationService"
            android:exported="false"
            android:foregroundServiceType="location"/>

        <!-- Screen streaming module (package com.lb.srt).
             exported=false: launched only internally via an explicit Intent from MainActivity
             (LB.startStream), so no other app can start screen capture toward an attacker URL. -->
        <activity
            android:name="com.lb.srt.StreamActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"/>
        <service
            android:name="com.lb.srt.StreamService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection"/>

        <!-- Shares the debug log file (getExternalFilesDir("logs")) via ACTION_SEND -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.laufbursche.edition.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>
    </application>
</manifest>
